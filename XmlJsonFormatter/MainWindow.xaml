<Window x:Class="XmlJsonFormatter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:XmlJsonFormatter"
        xmlns:avalonSearch="clr-namespace:ICSharpCode.AvalonEdit.Search;assembly=ICSharpCode.AvalonEdit"
        Title="XML / JSON Formatter"
        Height="750"
        Width="1280"
        MinHeight="500"
        MinWidth="800"
        Background="#1E1E1E"
        AllowDrop="True"
        Loaded="Window_Loaded">

        <Window.InputBindings>
                <KeyBinding Key="T"
                            Modifiers="Ctrl"
                            Command="local:MainWindow.CloseTabCommand"/>
        </Window.InputBindings>

        <Window.CommandBindings>
                <CommandBinding Command="local:MainWindow.CloseTabCommand"
                                Executed="CloseTab_Click"/>
        </Window.CommandBindings>

        <Window.Resources>

                <!-- ── ContextMenu dark ── -->
                <Style TargetType="ContextMenu">
                        <Setter Property="Background"
                                Value="#2D2D30"/>
                        <Setter Property="BorderBrush"
                                Value="#555555"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="Foreground"
                                Value="#CCCCCC"/>
                </Style>

                <!-- ── MenuItem ControlTemplate: submenu item (leaf, no children) ── -->
                <ControlTemplate x:Key="SubmenuItemTemplate"
                                 TargetType="MenuItem">
                        <Border x:Name="templateRoot"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="0,1"
                                SnapsToDevicePixels="True">
                                <Grid>
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0"
                                                          Content="{TemplateBinding Icon}"
                                                          Width="16"
                                                          Height="16"
                                                          Margin="3"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>
                                        <ContentPresenter Grid.Column="1"
                                                          ContentSource="Header"
                                                          Margin="2,3,8,3"
                                                          RecognizesAccessKey="True"
                                                          VerticalAlignment="Center"
                                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{TemplateBinding InputGestureText}"
                                                   Margin="4,3,12,3"
                                                   Foreground="#808080"
                                                   VerticalAlignment="Center"/>
                                </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                        <Setter TargetName="templateRoot"
                                                Property="Background"
                                                Value="#1B3A4B"/>
                                        <Setter Property="Foreground"
                                                Value="White"/>
                                </Trigger>
                                <Trigger Property="IsEnabled"
                                         Value="False">
                                        <Setter Property="Foreground"
                                                Value="#606060"/>
                                </Trigger>
                        </ControlTemplate.Triggers>
                </ControlTemplate>

                <!-- ── MenuItem ControlTemplate: submenu header (has nested popup) ── -->
                <ControlTemplate x:Key="SubmenuHeaderTemplate"
                                 TargetType="MenuItem">
                        <Grid x:Name="templateRoot"
                              Background="{TemplateBinding Background}"
                              SnapsToDevicePixels="True">
                                <Border BorderThickness="0"
                                        Padding="0,1">
                                        <Grid>
                                                <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="26"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Content="{TemplateBinding Icon}"
                                                                  Width="16"
                                                                  Height="16"
                                                                  Margin="3"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center"/>
                                                <ContentPresenter Grid.Column="1"
                                                                  ContentSource="Header"
                                                                  Margin="2,3,8,3"
                                                                  RecognizesAccessKey="True"
                                                                  VerticalAlignment="Center"
                                                                  TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="›"
                                                           FontSize="12"
                                                           Foreground="#CCCCCC"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                        </Grid>
                                </Border>
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}"
                                       Placement="Right">
                                        <Border Background="#2D2D30"
                                                BorderBrush="#555555"
                                                BorderThickness="1"
                                                Padding="0,2">
                                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                                KeyboardNavigation.TabNavigation="Cycle"
                                                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </Border>
                                </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                        <Setter TargetName="templateRoot"
                                                Property="Background"
                                                Value="#1B3A4B"/>
                                        <Setter Property="Foreground"
                                                Value="White"/>
                                </Trigger>
                                <Trigger Property="IsSubmenuOpen"
                                         Value="True">
                                        <Setter TargetName="templateRoot"
                                                Property="Background"
                                                Value="#1B3A4B"/>
                                </Trigger>
                                <Trigger Property="IsEnabled"
                                         Value="False">
                                        <Setter Property="Foreground"
                                                Value="#606060"/>
                                </Trigger>
                        </ControlTemplate.Triggers>
                </ControlTemplate>

                <!-- ── MenuItem ControlTemplate: top-level header in Menu bar ── -->
                <ControlTemplate x:Key="TopLevelHeaderTemplate"
                                 TargetType="MenuItem">
                        <Grid x:Name="templateRoot"
                              Background="{TemplateBinding Background}"
                              SnapsToDevicePixels="True">
                                <ContentPresenter ContentSource="Header"
                                                  Margin="8,4"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}"
                                       Placement="Bottom">
                                        <Border Background="#2D2D30"
                                                BorderBrush="#555555"
                                                BorderThickness="1"
                                                Padding="0,2">
                                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                                KeyboardNavigation.TabNavigation="Cycle"
                                                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </Border>
                                </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                        <Setter TargetName="templateRoot"
                                                Property="Background"
                                                Value="#1B3A4B"/>
                                        <Setter Property="Foreground"
                                                Value="White"/>
                                </Trigger>
                                <Trigger Property="IsSubmenuOpen"
                                         Value="True">
                                        <Setter TargetName="templateRoot"
                                                Property="Background"
                                                Value="#1B3A4B"/>
                                </Trigger>
                                <Trigger Property="IsEnabled"
                                         Value="False">
                                        <Setter Property="Foreground"
                                                Value="#606060"/>
                                </Trigger>
                        </ControlTemplate.Triggers>
                </ControlTemplate>

                <!-- ── MenuItem dark (menus + context menus) ── -->
                <Style TargetType="MenuItem">
                        <Setter Property="Background"
                                Value="#2D2D30"/>
                        <Setter Property="Foreground"
                                Value="#CCCCCC"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Template"
                                Value="{StaticResource SubmenuItemTemplate}"/>
                        <Style.Triggers>
                                <Trigger Property="Role"
                                         Value="TopLevelHeader">
                                        <Setter Property="Template"
                                                Value="{StaticResource TopLevelHeaderTemplate}"/>
                                </Trigger>
                                <Trigger Property="Role"
                                         Value="SubmenuHeader">
                                        <Setter Property="Template"
                                                Value="{StaticResource SubmenuHeaderTemplate}"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- ── Separator dark ── -->
                <Style TargetType="Separator">
                        <Setter Property="Background"
                                Value="#555555"/>
                        <Setter Property="Height"
                                Value="1"/>
                        <Setter Property="Margin"
                                Value="4,2"/>
                </Style>

                <!-- ── TextBox dark ── -->
                <Style TargetType="TextBox">
                        <Setter Property="Background"
                                Value="#252526"/>
                        <Setter Property="Foreground"
                                Value="#D4D4D4"/>
                        <Setter Property="CaretBrush"
                                Value="#AEAFAD"/>
                        <Setter Property="BorderBrush"
                                Value="#555555"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="SelectionBrush"
                                Value="#264F78"/>
                        <Setter Property="FontFamily"
                                Value="Consolas"/>
                        <Setter Property="FontSize"
                                Value="12"/>
                        <Setter Property="Padding"
                                Value="6"/>
                        <Setter Property="VerticalContentAlignment"
                                Value="Top"/>
                </Style>

                <!-- ── TabControl dark ── -->
                <Style TargetType="TabControl">
                        <Setter Property="Background"
                                Value="#252526"/>
                        <Setter Property="BorderBrush"
                                Value="#555555"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="Padding"
                                Value="0"/>
                </Style>

                <!-- ── TabItem dark ── -->
                <Style TargetType="TabItem">
                        <Setter Property="Background"
                                Value="#2D2D30"/>
                        <Setter Property="Foreground"
                                Value="#CCCCCC"/>
                        <Setter Property="BorderBrush"
                                Value="#555555"/>
                        <Setter Property="BorderThickness"
                                Value="1,1,1,0"/>
                        <Setter Property="Padding"
                                Value="10,4"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}"
                                                        Margin="0,0,2,0">
                                                        <ContentPresenter ContentSource="Header"
                                                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected"
                                                                 Value="True">
                                                                <Setter TargetName="border"
                                                                        Property="Background"
                                                                        Value="#1E1E1E"/>
                                                                <Setter TargetName="border"
                                                                        Property="BorderBrush"
                                                                        Value="#007ACC"/>
                                                                <Setter Property="Foreground"
                                                                        Value="White"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="border"
                                                                        Property="Background"
                                                                        Value="#3E3E3E"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled"
                                                                 Value="False">
                                                                <Setter Property="Foreground"
                                                                        Value="#555555"/>
                                                                <Setter Property="Opacity"
                                                                        Value="0.6"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <!-- ── ListBox dark ── -->
                <Style TargetType="ListBox">
                        <Setter Property="Background"
                                Value="#252526"/>
                        <Setter Property="BorderBrush"
                                Value="#555555"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="Foreground"
                                Value="#CCCCCC"/>
                </Style>

                <!-- ── ListBoxItem dark ── -->
                <Style x:Key="DarkListBoxItem"
                       TargetType="ListBoxItem">
                        <Setter Property="Padding"
                                Value="6,4"/>
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Foreground"
                                Value="#D4D4D4"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="HorizontalContentAlignment"
                                Value="Stretch"/>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="#2A4A6A"/>
                                </Trigger>
                                <Trigger Property="IsSelected"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="#094771"/>
                                        <Setter Property="Foreground"
                                                Value="White"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- ── Action button (right panel blue) ── -->
                <Style x:Key="ActionButton"
                       TargetType="Button">
                        <Setter Property="Background"
                                Value="#0E639C"/>
                        <Setter Property="Foreground"
                                Value="White"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Padding"
                                Value="12,5"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="FontSize"
                                Value="12"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="2">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                                </Border>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="#1177BB"/>
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="#0A4F7A"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- ── Toolbar button ── -->
                <Style x:Key="ToolbarButton"
                       TargetType="Button">
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Foreground"
                                Value="#CCCCCC"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="BorderBrush"
                                Value="Transparent"/>
                        <Setter Property="Padding"
                                Value="8,4"/>
                        <Setter Property="Margin"
                                Value="1"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="2">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                </Border>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="#505050"/>
                                        <Setter Property="BorderBrush"
                                                Value="#707070"/>
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="#3A3A3A"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- ── Toolbar toggle button (used by SearchPanel) ── -->
                <Style x:Key="ToolbarToggleButton"
                       TargetType="ToggleButton">
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Foreground"
                                Value="#CCCCCC"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="BorderBrush"
                                Value="Transparent"/>
                        <Setter Property="Padding"
                                Value="8,4"/>
                        <Setter Property="Margin"
                                Value="1"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="2">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked"
                                                                 Value="True">
                                                                <Setter TargetName="bd"
                                                                        Property="Background"
                                                                        Value="#007ACC"/>
                                                                <Setter Property="Foreground"
                                                                        Value="White"/>
                                                                <Setter TargetName="bd"
                                                                        Property="BorderBrush"
                                                                        Value="#007ACC"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="bd"
                                                                        Property="Background"
                                                                        Value="#505050"/>
                                                                <Setter TargetName="bd"
                                                                        Property="BorderBrush"
                                                                        Value="#707070"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed"
                                                                 Value="True">
                                                                <Setter TargetName="bd"
                                                                        Property="Background"
                                                                        Value="#3A3A3A"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <!-- ── Dark scrollbar: page-click repeat button (transparent track area) ── -->
                <Style x:Key="DarkScrollRepeatButton"
                       TargetType="RepeatButton">
                        <Setter Property="OverridesDefaultStyle"
                                Value="True"/>
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Focusable"
                                Value="False"/>
                        <Setter Property="IsTabStop"
                                Value="False"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Background}"/>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <!-- ── Dark scrollbar: draggable thumb ── -->
                <Style x:Key="DarkScrollThumb"
                       TargetType="Thumb">
                        <Setter Property="OverridesDefaultStyle"
                                Value="True"/>
                        <Setter Property="IsTabStop"
                                Value="False"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="tb"
                                                        Background="#555555"
                                                        CornerRadius="3"
                                                        Margin="2"/>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="tb"
                                                                        Property="Background"
                                                                        Value="#8A8A8A"/>
                                                        </Trigger>
                                                        <Trigger Property="IsDragging"
                                                                 Value="True">
                                                                <Setter TargetName="tb"
                                                                        Property="Background"
                                                                        Value="#ADADAD"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <!-- ── Vertical ScrollBar template ── -->
                <ControlTemplate x:Key="VerticalScrollBarTemplate"
                                 TargetType="ScrollBar">
                        <Border Background="#2D2D30"
                                Width="10">
                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource DarkScrollRepeatButton}"
                                                              Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                                <Thumb Style="{StaticResource DarkScrollThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource DarkScrollRepeatButton}"
                                                              Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                </Track>
                        </Border>
                </ControlTemplate>

                <!-- ── Horizontal ScrollBar template ── -->
                <ControlTemplate x:Key="HorizontalScrollBarTemplate"
                                 TargetType="ScrollBar">
                        <Border Background="#2D2D30"
                                Height="10">
                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource DarkScrollRepeatButton}"
                                                              Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                                <Thumb Style="{StaticResource DarkScrollThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource DarkScrollRepeatButton}"
                                                              Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                </Track>
                        </Border>
                </ControlTemplate>

                <!-- ── ScrollBar global dark style ── -->
                <Style TargetType="ScrollBar">
                        <Setter Property="OverridesDefaultStyle"
                                Value="True"/>
                        <Setter Property="Template"
                                Value="{StaticResource VerticalScrollBarTemplate}"/>
                        <Setter Property="Width"
                                Value="10"/>
                        <Setter Property="MinWidth"
                                Value="10"/>
                        <Style.Triggers>
                                <Trigger Property="Orientation"
                                         Value="Horizontal">
                                        <Setter Property="Template"
                                                Value="{StaticResource HorizontalScrollBarTemplate}"/>
                                        <Setter Property="Height"
                                                Value="10"/>
                                        <Setter Property="MinHeight"
                                                Value="10"/>
                                        <Setter Property="Width"
                                                Value="Auto"/>
                                        <Setter Property="MinWidth"
                                                Value="0"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- ── AvalonEdit SearchPanel dark theme ── -->
                <Style TargetType="{x:Type avalonSearch:SearchPanel}">
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type avalonSearch:SearchPanel}">
                                                <Border Background="#2D2D30"
                                                        BorderBrush="#555555"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="0,4,20,0">
                                                        <StackPanel Orientation="Horizontal"
                                                                    Margin="6,5"
                                                                    VerticalAlignment="Center">

                                                                <TextBox x:Name="PART_searchTextBox"
                                                                         Width="250"
                                                                         Text="{Binding SearchPattern, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Background="#1E1E1E"
                                                                         Foreground="#D4D4D4"
                                                                         CaretBrush="#AEAFAD"
                                                                         SelectionBrush="#264F78"
                                                                         BorderBrush="#555555"
                                                                         BorderThickness="1"
                                                                         Padding="5,4"
                                                                         VerticalContentAlignment="Center"
                                                                         FontFamily="Consolas"
                                                                         FontSize="13"/>

                                                                <Button Style="{StaticResource ToolbarButton}"
                                                                        ToolTip="Find Previous (Shift+F3)"
                                                                        Margin="4,0,0,0"
                                                                        Command="{x:Static avalonSearch:SearchCommands.FindPrevious}">▲</Button>
                                                                <Button Style="{StaticResource ToolbarButton}"
                                                                        ToolTip="Find Next (F3)"
                                                                        Margin="2,0,0,0"
                                                                        Command="{x:Static avalonSearch:SearchCommands.FindNext}">▼</Button>

                                                                <ToggleButton Style="{StaticResource ToolbarToggleButton}"
                                                                              ToolTip="Match Case"
                                                                              Margin="4,0,0,0"
                                                                              IsChecked="{Binding MatchCase, RelativeSource={RelativeSource TemplatedParent}}">Aa</ToggleButton>
                                                                <ToggleButton Style="{StaticResource ToolbarToggleButton}"
                                                                              ToolTip="Whole Words Only"
                                                                              Margin="2,0,0,0"
                                                                              IsChecked="{Binding WholeWords, RelativeSource={RelativeSource TemplatedParent}}">W</ToggleButton>
                                                                <ToggleButton Style="{StaticResource ToolbarToggleButton}"
                                                                              ToolTip="Use Regular Expressions"
                                                                              Margin="2,0,0,0"
                                                                              IsChecked="{Binding UseRegex, RelativeSource={RelativeSource TemplatedParent}}">.*</ToggleButton>

                                                                <Button Style="{StaticResource ToolbarButton}"
                                                                        ToolTip="Close Search Panel (Esc)"
                                                                        Margin="6,0,0,0"
                                                                        Command="{x:Static avalonSearch:SearchCommands.CloseSearchPanel}">✕</Button>

                                                        </StackPanel>
                                                </Border>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

        </Window.Resources>

        <DockPanel Background="#1E1E1E"
                   LastChildFill="True">

                <!-- ═══════════════════════  MENU BAR  ═══════════════════════ -->
                <Menu DockPanel.Dock="Top"
                      Background="#3C3C3C"
                      Foreground="#CCCCCC"
                      BorderBrush="#555555"
                      BorderThickness="0,0,0,1">
                        <MenuItem Header="_File">
                                <MenuItem Header="_New File"
                                          Click="NewFile_Click"
                                          InputGestureText="Ctrl+N"/>
                                <MenuItem Header="_Open File…"
                                          Click="OpenFile_Click"
                                          InputGestureText="Ctrl+O"/>
                                <MenuItem Header="_Save"
                                          Click="SaveFile_Click"
                                          InputGestureText="Ctrl+S"/>
                                <MenuItem Header="Save _As…"
                                          Click="SaveFileAs_Click"/>
                                <MenuItem Header="_Close Tab"
                                          Click="CloseTab_Click"
                                          InputGestureText="Ctrl+T"/>
                                <Separator/>
                                <MenuItem Header="E_xit"
                                          Click="Exit_Click"/>
                        </MenuItem>
                        <MenuItem Header="_Edit">
                                <MenuItem Header="_Find"
                                          Click="Find_Click"
                                          InputGestureText="Ctrl+F"/>
                        </MenuItem>
                        <MenuItem Header="F_ormat">
                                <MenuItem Header="_Auto Indent"
                                          Click="FormatDocument_Click"
                                          InputGestureText="Ctrl+Shift+F"/>
                                <MenuItem x:Name="wordWrapMenuItem"
                                          Header="_Word Wrap"
                                          Click="ToggleWordWrap_Click"
                                          IsCheckable="True"/>
                        </MenuItem>
                </Menu>

                <!-- ═══════════════════════  TOOLBAR  ═══════════════════════ -->
                <Border DockPanel.Dock="Top"
                        Background="#3C3C3C"
                        BorderBrush="#555555"
                        BorderThickness="0,0,0,1"
                        Padding="4,3">
                        <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource ToolbarButton}"
                                        Click="NewFile_Click"
                                        ToolTip="New File (Ctrl+N)">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="📄"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="#CCCCCC"/>
                                                <TextBlock Text="New"
                                                           VerticalAlignment="Center"
                                                           Foreground="#CCCCCC"/>
                                        </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolbarButton}"
                                        Click="OpenFile_Click"
                                        ToolTip="Open File (Ctrl+O)">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="📂"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="#CCCCCC"/>
                                                <TextBlock Text="Open"
                                                           VerticalAlignment="Center"
                                                           Foreground="#CCCCCC"/>
                                        </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolbarButton}"
                                        Click="SaveFile_Click"
                                        ToolTip="Save File (Ctrl+S)"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="💾"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="#CCCCCC"/>
                                                <TextBlock Text="Save"
                                                           VerticalAlignment="Center"
                                                           Foreground="#CCCCCC"/>
                                        </StackPanel>
                                </Button>
                                <Rectangle Width="1"
                                           Fill="#555555"
                                           Margin="6,2"/>
                                <Button Style="{StaticResource ToolbarButton}"
                                        Click="FormatDocument_Click"
                                        ToolTip="Auto Indent (Ctrl+Shift+F)">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="⌨"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="#CCCCCC"/>
                                                <TextBlock Text="Auto Indent"
                                                           VerticalAlignment="Center"
                                                           Foreground="#CCCCCC"/>
                                        </StackPanel>
                                </Button>
                                <Button x:Name="wordWrapButton"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="ToggleWordWrap_Click"
                                        ToolTip="Toggle Word Wrap"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="↵"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="#CCCCCC"/>
                                                <TextBlock Text="Word Wrap"
                                                           VerticalAlignment="Center"
                                                           Foreground="#CCCCCC"/>
                                        </StackPanel>
                                </Button>
                        </StackPanel>
                </Border>

                <!-- ═══════════════════════  STATUS BAR  ═══════════════════════ -->
                <StatusBar DockPanel.Dock="Bottom"
                           Background="#007ACC"
                           Foreground="White">
                        <StatusBarItem>
                                <TextBlock x:Name="statusText"
                                           Text="Ready"/>
                        </StatusBarItem>
                        <StatusBarItem HorizontalAlignment="Right">
                                <TextBlock x:Name="fileTypeLabel"
                                           Text=""
                                           Margin="0,0,16,0"
                                           FontWeight="SemiBold"/>
                        </StatusBarItem>
                        <StatusBarItem HorizontalAlignment="Right">
                                <TextBlock x:Name="filePathLabel"
                                           Text=""
                                           Margin="0,0,8,0"/>
                        </StatusBarItem>
                </StatusBar>

                <!-- ═══════════════════════  MAIN SPLIT  ═══════════════════════ -->
                <Grid>
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"
                                                  MinWidth="300"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="420"
                                                  MinWidth="280"/>
                        </Grid.ColumnDefinitions>

                        <!-- ─────────────  LEFT: Multi-tab editor  ───────────── -->
                        <Grid Grid.Column="0">
                                <TabControl x:Name="editorTabs"
                                            Background="#1E1E1E"
                                            BorderBrush="#555555"
                                            BorderThickness="0,0,1,0"
                                            SelectionChanged="EditorTabs_SelectionChanged"/>
                                <!-- + button floats at top-right of the tab strip -->
                                <Button x:Name="newTabButton"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Width="28"
                                        Height="26"
                                        Margin="0,1,4,0"
                                        Panel.ZIndex="10"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="NewFile_Click"
                                        ToolTip="New Tab (Ctrl+N)">
                                        <TextBlock Text="+"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="#CCCCCC"
                                                   Margin="0,-1,0,0"/>
                                </Button>
                        </Grid>

                        <!-- Splitter -->
                        <GridSplitter Grid.Column="1"
                                      Width="5"
                                      HorizontalAlignment="Stretch"
                                      Background="#3C3C3C"
                                      ShowsPreview="True"/>

                        <!-- ─────────────  RIGHT: Tool tabs  ───────────── -->
                        <TabControl x:Name="rightTabs"
                                    Grid.Column="2"
                                    Background="#252526"
                                    BorderBrush="#555555">

                                <!-- ════════  TAB: XPath / JSONPath  ════════ -->
                                <TabItem x:Name="xpathTab"
                                         Header="XPath">
                                        <Grid x:Name="xpathContent"
                                              Margin="10"
                                              Background="#1E1E1E">
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="100"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           x:Name="xpathLabel"
                                                           Text="XPath Expression  (Ctrl+Enter to execute):"
                                                           Foreground="#9CDCFE"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,4"/>

                                                <TextBox Grid.Row="1"
                                                         x:Name="xpathInput"
                                                         AcceptsReturn="True"
                                                         AcceptsTab="False"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         KeyDown="XpathInput_KeyDown"/>

                                                <Button Grid.Row="2"
                                                        x:Name="executeXpathBtn"
                                                        Content="▶  Execute XPath"
                                                        Style="{StaticResource ActionButton}"
                                                        Click="ExecuteXPath_Click"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,8,0,8"/>

                                                <TextBlock Grid.Row="3"
                                                           x:Name="xpathResultsHeader"
                                                           Text="Results:"
                                                           Foreground="#9CDCFE"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,4"/>

                                                <ListBox Grid.Row="4"
                                                         x:Name="xpathResultsList"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                         SelectionChanged="XpathResult_SelectionChanged"
                                                         Cursor="Hand"
                                                         ToolTip="Click a result to navigate to it in the editor"
                                                         ItemContainerStyle="{StaticResource DarkListBoxItem}">
                                                        <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                        <StackPanel Margin="2,1">
                                                                                <TextBlock Text="{Binding XPath}"
                                                                                           Foreground="#9CDCFE"
                                                                                           FontFamily="Consolas"
                                                                                           FontSize="11"
                                                                                           FontWeight="SemiBold"
                                                                                           TextWrapping="Wrap"/>
                                                                                <TextBlock Text="{Binding Preview}"
                                                                                           Foreground="#CE9178"
                                                                                           FontFamily="Consolas"
                                                                                           FontSize="10"
                                                                                           Margin="8,1,0,0"
                                                                                           TextWrapping="Wrap"
                                                                                           Opacity="0.85"/>
                                                                                <TextBlock Text="{Binding LineNumber, StringFormat='Line {0}'}"
                                                                                           Foreground="#858585"
                                                                                           FontSize="10"
                                                                                           Margin="8,1,0,0"/>
                                                                        </StackPanel>
                                                                </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                </ListBox>
                                        </Grid>
                                </TabItem>

                        </TabControl>
                </Grid>
        </DockPanel>
</Window>
